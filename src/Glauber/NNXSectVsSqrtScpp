  double NNProfile::evaluate(double x)
  {
  return _g*(1-TMath::Gamma(_omegaInv,_gOverOmegaR2*x*x));
  }

  void NNProfile::reset()
  {
  _xSection = 0.0;
  _omega = 0.0;
  _g = 0.0;
  _r2 = 0.0;
  _omegaInv = 0.0;
  _gOverOmegaR2 = 0.0;
  }

  SmearingProfile::SmearingProfile()
  :
  _nucleonSigma(0.0)
  {  }

  SmearingProfile::SmearingProfile(const SmearingProfile & src)
  :
  _nucleonSigma(src._nucleonSigma)
  {  }

   SmearingProfile & SmearingProfile::operator=(const SmearingProfile & rhs)
  {
   if (this!=&rhs)
     {
     _nucleonSigma = rhs._nucleonSigma;
     }
   return *this;
   }

  virtual void setNucleonSigma(double value)
  {
  if (value<=0.0)
    throw GlauberException("nucleonSigma<=0",__FUNCTION__);
  _nucleonSigma = value;
  _twoNucleonSigmaSq = 2.0*_nucleonSigma*_nucleonSigma;
  }

  void SmearingProfile::reset()
  {
  _nucleonSigma   = 0.0;
  _twoNucleonSigmaSq = 0.0;
  }

  double SmearingProfile::evaluate(double x)
  {
  return x*exp(-x*x/_twoNucleonSigmaSq);
  }

  PTotProfile::PTotProfile()
  :
  _nnXSect(0),
  _nnXSectOmega(0),
  _nnXSectLambda(0)
  { }

  PTotProfile::PTotProfile(const PTotProfile & src)
  :
  _nnXSect(src._nnXSect),
  _nnXSectOmega(src._nnXSectOmega),
  _nnXSectLambda(src._nnXSectLambda)
  { }

  PTotProfile & PTotProfile::operator=(const PTotProfile & rhs)
  {
  if (this!=&rhs)
    {
    _nnXSect       = rhs._nnXSect;
    _nnXSectOmega  = rhs._nnXSectOmega;
    _nnXSectLambda = rhs._nnXSectLambda;
    }
  return *this;
  }

  double PTotProfile::evaluate(double x)
  {
  // [0] _nnXSect,
  // [1] _nnXSectOmega,
  // [2] _nnXSectLambda
  double xr = x/_nnXSectLambda;
  double ss = _nnXSectOmega*_nnXSectOmega;
  double aa = xr/_nnXSect-1.0
  return (xr/(xr+_nnXSect))*exp(-aa*aa/ss)/_nnXSectLambda;
  }

  NucleonProfile::NucleonProfile()
  :
  _nucleonRadius(0)
  { }

  NucleonProfile::NucleonProfile(const NucleonProfile & src)
  :
  _nucleonRadius(src._nucleonRadius)
  { }


  NucleonProfile & NucleonProfile::operator=(const NucleonProfile & rhs)
  {
  if (this!=&rhs)
    {
    _nucleonRadius = rhs._nucleonRadius;
    }
  return *this;
  }

  void NucleonProfile::setNucleonRadius(double value)
  {
  if (value<=0.0)
    throw GlauberException("nucleonRadius<=0",__FUNCTION__);
  _nucleonRadius = value;
  }

  double NucleonProfile::evaluate(double x)
  {
  return x*x*exp(-x/_nucleonRadius);
  }

